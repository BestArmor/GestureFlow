<Window x:Class="GestureFlow.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GestureFlow" Width="1100" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F1E" Foreground="#FFFFFF" FontFamily="Segoe UI">
    <Window.Resources>
        <LinearGradientBrush x:Key="PurpleGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF50B4" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="BorderBrush" Value="#2D2D44"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PurpleGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#1E1E2E" Padding="30,20">
            <Grid>
                <TextBlock Text="💜 GestureFlow" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PurpleGradient}"/>
                <Border HorizontalAlignment="Right" Background="#2D2D44" CornerRadius="8" Padding="12,6">
                    <TextBlock Text="v0.9.5" Foreground="#8B8BA7"/>
                </Border>
            </Grid>
        </Border>
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="20">
            <TabItem Header="🎬 Жесты">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel Margin="0,10,0,0">
                        <Border Style="{StaticResource Card}" Width="300">
                            <StackPanel>
                                <TextBlock Text="←" FontSize="32" Foreground="#A855F7"/>
                                <TextBlock Text="Свайп влево" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <TextBlock Text="Назад в браузере" Foreground="#8B8BA7"/>
                                <Border Background="#2D2D44" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <TextBlock Text="Alt+Left" FontSize="12" Foreground="#A0A0B8" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Width="300">
                            <StackPanel>
                                <TextBlock Text="→" FontSize="32" Foreground="#A855F7"/>
                                <TextBlock Text="Свайп вправо" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <TextBlock Text="Вперёд в браузере" Foreground="#8B8BA7"/>
                                <Border Background="#2D2D44" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <TextBlock Text="Alt+Right" FontSize="12" Foreground="#A0A0B8" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Width="300">
                            <StackPanel>
                                <TextBlock Text="↑" FontSize="32" Foreground="#A855F7"/>
                                <TextBlock Text="Свайп вверх" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <TextBlock Text="Новая вкладка" Foreground="#8B8BA7"/>
                                <Border Background="#2D2D44" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <TextBlock Text="Ctrl+T" FontSize="12" Foreground="#A0A0B8" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Width="300">
                            <StackPanel>
                                <TextBlock Text="↓" FontSize="32" Foreground="#A855F7"/>
                                <TextBlock Text="Свайп вниз" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <TextBlock Text="Закрыть вкладку" Foreground="#8B8BA7"/>
                                <Border Background="#2D2D44" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <TextBlock Text="Ctrl+W" FontSize="12" Foreground="#A0A0B8" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Width="300">
                            <StackPanel>
                                <TextBlock Text="⭕" FontSize="32" Foreground="#A855F7"/>
                                <TextBlock Text="Круг" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <TextBlock Text="Обновить страницу" Foreground="#8B8BA7"/>
                                <Border Background="#2D2D44" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <TextBlock Text="F5" FontSize="12" Foreground="#A0A0B8" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Width="300">
                            <StackPanel>
                                <TextBlock Text="✓" FontSize="32" Foreground="#A855F7"/>
                                <TextBlock Text="Галочка" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <TextBlock Text="Свернуть окно" Foreground="#8B8BA7"/>
                                <Border Background="#2D2D44" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,10,0,0">
                                    <TextBlock Text="MINIMIZE" FontSize="12" Foreground="#A0A0B8" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="⚙️ Настройки">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,10,0,0" MaxWidth="600" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="🎨 Скин трейла" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Выберите визуальный стиль" Foreground="#8B8BA7" Margin="0,4,0,12"/>
                                <ComboBox x:Name="SkinComboBox" SelectionChanged="SkinComboBox_SelectionChanged" Height="40" Background="#2D2D44" Foreground="White">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="📄 settings.json" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Тонкая настройка" Foreground="#8B8BA7" Margin="0,4,0,12"/>
                                <Button Content="Открыть файл" Style="{StaticResource Btn}" Click="OpenSettings_Click" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="🖌️ Свои скины" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Папка skins/" Foreground="#8B8BA7" Margin="0,4,0,12"/>
                                <Button Content="Открыть папку" Style="{StaticResource Btn}" Click="OpenSkinsFolder_Click" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="ℹ️ О программе">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,10,0,0" MaxWidth="600" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="GestureFlow v0.9.5" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PurpleGradient}"/>
                                <TextBlock Text="Control your PC with a flick of your wrist" Foreground="#8B8BA7" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="🔗 GitHub" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <Button Content="Открыть репозиторий" Style="{StaticResource Btn}" Click="OpenGitHub_Click" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
